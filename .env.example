# Backend
# Comma-separated list of allowed CORS origins. Examples:
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# CORS_ALLOW_ORIGINS=*   (disables credentials)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Path to YOLO model weights
FAULT_MODEL_PATH=backend/models/best.pt
FAULT_TYPE_MODEL_PATH=backend/models/best_8_class.pt
FAULT_IMGSZ=1280
FAULT_CONF=0.20
FAULT_IOU=0.50

# Frontend (build-time for Vite)
# If you deploy frontend separately from backend, set an absolute URL like:
# VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
