# Git/OS
.git
.gitignore

# Python
**/__pycache__/
**/*.pyc
**/*.pyo
.venv/

# Node/Vite
**/node_modules/
frontend/dist/

# App runtime outputs / large private data
backups/
data/
backend/thermal_out/
backend/static/orthomosaic_sessions/

# ML weights (keep out of build context; mount at runtime)
**/*.pt
**/*.onnx

# Allow only the two default weights to be baked into the image when present.
!backend/models/best.pt
!backend/models/best_8_class.pt

# Editor
.vscode/
.DS_Store
